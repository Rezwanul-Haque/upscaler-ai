COMPOSE_PROJECT_NAME=upscaler-ai

BRAND_NAME=Upscaler AI

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# Storage
UPLOAD_DIR=./data/uploads
OUTPUT_DIR=./data/outputs
MAX_UPLOAD_SIZE_MB=50

# Database
DATABASE_URL=sqlite:///./data/upscaler.db

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:1420

# Upscaler provider — options: pillow (default)
UPSCALER_PROVIDER=pillow

# Storage provider — options: local (default) | future: s3, r2, gcs
STORAGE_PROVIDER=local
